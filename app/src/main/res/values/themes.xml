<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Satra" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/satra_background_light</item>
        <item name="android:navigationBarColor">@color/satra_background_light</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <style name="Theme.Satra.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/satra_ink</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.Satra</item>
    </style>
</resources>
